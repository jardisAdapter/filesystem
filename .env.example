# Docker
DOCKER_HUB=headgent
COMPOSE_FILE=support/docker-compose.yml
COMPOSE_PROJECT_NAME=filesystem

# PHP
PHP_VERSION=8.3
PHP_IMAGE_NAME=phpcli
PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=0
PHP_TIMEZONE=UTC
PHP_ERROR_REPORTING=E_ALL & ~E_DEPRECATED & ~E_STRICT
PHP_DISPLAY_ERRORS=Off
PHP_LOG_ERRORS=On
APCU_SHM_SIZE=64M
OPCACHE_MEMORY_CONSUMPTION=128
OPCACHE_MAX_ACCELERATED_FILES=4000
OPCACHE_REVALIDATE_FREQ=2
OPCACHE_JIT=1254
OPCACHE_JIT_BUFFER_SIZE=128M

# Xdebug
XDEBUG_MODE=debug
XDEBUG_START_WITH_REQUEST=yes
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_CLIENT_PORT=9003
XDEBUG_LOG_LEVEL=0

# PCOV
PCOV_ENABLED=0

# Filesystem Driver
#FS_DRIVER=local                            # local | s3 (Default: local)

# Local Adapter
#FS_LOCAL_ROOT=/var/app/storage             # Root-Verzeichnis (Pflicht bei local)
#FS_LOCAL_PERMISSIONS_FILE=0644             # File Permissions (Default: 0644)
#FS_LOCAL_PERMISSIONS_DIR=0755              # Directory Permissions (Default: 0755)

# S3 Adapter
#FS_S3_BUCKET=my-bucket                     # S3 Bucket Name
#FS_S3_REGION=eu-central-1                  # AWS Region
#FS_S3_KEY=                                 # Access Key ID
#FS_S3_SECRET=                              # Secret Access Key
#FS_S3_ENDPOINT=https://s3.amazonaws.com    # Endpoint (fuer MinIO/DO Spaces: custom URL)
#FS_S3_PREFIX=                              # Pfad-Prefix im Bucket (optional)

# MinIO (Test)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=testbucket
MINIO_REGION=us-east-1
